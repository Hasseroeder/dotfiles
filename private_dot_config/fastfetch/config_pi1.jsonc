{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
  "logo": {
    "source": "~/.config/fastfetch/ASCII/cd.txt",
    "padding": {
      "left": 2,
      "right": 3,
      "top": 1
    },
    "color": {
      "1": "#ccccff"
    }
  },
  "modules": [
    "break",
    {
      "type": "command",
      "key":" ",
      "text": "~/.config/fastfetch/header.sh 2 System 59"
    },
    {
      "type": "os",
      "key": " ┌  OS       ",
      "format": "{pretty-name}",
      "keyColor":"#ccccff"
    },
    {
      "type": "kernel",
      "key": " ├ 󰌽 Kernel   ",
      "format": "{release}",
      "keyColor":"#ccccff"
    },
    {
      "type": "uptime",
      "key": " ├ 󱎫 Uptime   ",
      "keyColor":"#ccccff"
    },
    {
      "type": "packages",
      "key": " ├  Pkgs     ",
      "keyColor":"#ccccff"
    },
    {
      "type": "shell",
      "key": " └ 󰆍 Shell    ",
      "keyColor":"#ccccff"
    },
    "break",
    {
      "type": "command",
      "key":" ",
      "text": "~/.config/fastfetch/header.sh 2 Hardware 59"
    },
    {
      "type": "cpu",
      "key": " ┌  CPU      ",
      "format": "{name} - {march}",
      "keyColor":"#ccccff"
    },
    {
      "type": "memory",
      "key": " ├  RAM      ",
      "format": "{used}/{total} ({percentage})",
      "keyColor":"#ccccff"
    },
    {
      "type": "command",
      "key": " ├  Swap     ",
      "text": "[ \"$(free -h | awk '/Swap/ {print $2}')\" = \"0B\" ] && echo \"Disabled\" || echo \"Enabled\"",
      "keyColor":"#ccccff"
    },
    {
      "type": "command",
      "key": " ├  /        ",
      "text": "~/.config/fastfetch/disk.sh /",
      "keyColor":"#ccccff"
    },
    {
      "type": "command",
      "key": " └  /mnt/ssd ",
      "text": "~/.config/fastfetch/disk.sh /mnt/ssd",
      "keyColor":"#ccccff"
    },
    "break",
    {
      "type": "command",
      "key":" ",
      "text": "~/.config/fastfetch/header.sh 2 Session 59"
    },
    {
      "type": "title",
      "key": " ┌  Host     ",
      "format": "{user-name}@{host-name}",
      "keyColor":"#ccccff"
    },
    { 
      "type": "command", 
      "key": " ├ 󰌘 Ipv4     ",
      "text": "~/.config/fastfetch/ssh_ipv4.sh", 
      "keyColor":"#ccccff"
    },
    {
      "type": "locale",
      "key": " ├ 󰊷 Locale   ",
      "keyColor":"#ccccff"
    },   
    {
      "type": "command",
      "key": " ├  Time     ",
      "text": "~/.config/fastfetch/time.sh",
      "keyColor":"#ccccff"
    },
    {
      "type": "terminal",
      "key": " └ 󰆍 Terminal ",
      "keyColor":"#ccccff"
    },
    "break",
    {
      "type": "command",
      "key":" ",
      "text": "~/.config/fastfetch/header.sh 2 Syncthing 59"
    },
    {
      "type": "command",
      "key": " ┌  Version   ",
      "keyColor":"#ccccff",
      "text": "syncthing --version | awk '{print $1 \" \" $2}'"
    },
    {
      "type": "command",
      "key": " ├  Activity  ",
      "keyColor":"#ccccff",
      "text":"~/.config/fastfetch/bool_writer.sh $(systemctl --user is-active syncthing.service >/dev/null; echo $?)"
    },
    {
      "type": "command",
      "key": " └  Uptime    ",
      "keyColor":"#ccccff",
      "text":"~/.config/fastfetch/timestamp_to_uptime.sh \"$(systemctl --user show syncthing.service -p ActiveEnterTimestamp | cut -d= -f2)\""
    },
    "break",
    "colors"
  ]
}
